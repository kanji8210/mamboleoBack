# Copy to .env and fill in values
  MAMBOLEO_WP_URL=https://mamboleole.com
  MAMBOLEO_API_KEY=mk_live_7b58ac5e36ae0aa8d14608770440baafba42902464525a5b
  
  # Twitter/X API v2 — Bearer Token (read-only, free Basic tier is enough)
  TWITTER_BEARER_TOKEN=
  
  # Scraping behaviour
  SCRAPER_DELAY=2.5          # seconds between HTTP requests
  MAX_ARTICLES_PER_RUN=30    # max articles processed per scraper run
  
  # ── AI / LLM provider ────────────────────────────────────────────────────────
  # Using Groq (free tier, OpenAI-compatible, fast Llama 3.1).
  LLM_PROVIDER=openai
  OLLAMA_ENABLED=1
  
  # Local Ollama (unused while LLM_PROVIDER=openai, kept for fallback)
  OLLAMA_HOST=http://localhost:11434
  OLLAMA_MODEL=llama3.1:8b
  OLLAMA_TIMEOUT=45
  
  # Groq (OpenAI-compatible)
  OPENAI_BASE_URL=https://api.groq.com/openai/v1
  OPENAI_API_KEY=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
  OPENAI_MODEL=llama-3.1-8b-instant
  OPENAI_TIMEOUT=60
