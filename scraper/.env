# Mamboleo scraper — runtime secrets.
# IMPORTANT: never commit this file. The .gitignore already excludes it.
#
# Only TWO secrets live here:
#   1. The WordPress site URL (where to push data)
#   2. The plugin's ingestion API key (auth for /wp-json/m amboleo/v1/*)
#
# Everything else (LLM provider, model, OpenAI/Groq key) is configured in
# WP admin → Mamboleo → AI Intelligence and pulled at startup via
# /wp-json/mamboleo/v1/llm-config — there is no need to duplicate keys here.

MAMBOLEO_WP_URL=https://mamboleole.com
MAMBOLEO_API_KEY=mk_live_7b58ac5e36ae0aa8d14608770440baafba42902464525a5b

# Optional: Twitter/X v2 Bearer Token.
# Source of truth is WP admin → Mamboleo → Social Sources. This env var is
# only a fallback that lets the scraper run before the admin form is filled.
# Free Basic tier is enough for our budget.
TWITTER_BEARER_TOKEN=

# Optional: self-hosted RSSHub bridge for Facebook page scraping.
# Source of truth is WP admin → Mamboleo → Social Sources. Env is fallback.
RSSHUB_HOST=http://localhost:1200

# Scraping behaviour (safe defaults, rarely changed)
SCRAPER_DELAY=2.5
MAX_ARTICLES_PER_RUN=30
