# Copy to .env and fill in values
MAMBOLEO_WP_URL=http://localhost/wordpress
MAMBOLEO_API_KEY=mamboleo-dev-key-change-in-production

# Twitter/X API v2 — Bearer Token (read-only, free Basic tier is enough)
TWITTER_BEARER_TOKEN=

# Scraping behaviour
SCRAPER_DELAY=2.5          # seconds between HTTP requests
MAX_ARTICLES_PER_RUN=30    # max articles processed per scraper run

# Optional self-hosted RSSHub bridge for Facebook page scraping.
# When set, social_sources.yaml entries with platform: facebook are pulled
# via {RSSHUB_HOST}/facebook/page/{handle}. Leave empty to skip FB sources.
RSSHUB_HOST=

# ── AI / LLM provider ────────────────────────────────────────────────────────
# Pick one provider. Default is "ollama" (fully offline, free).
# Set to "openai" to use any OpenAI Chat-Completions-compatible endpoint
# (OpenAI, Groq, Together.ai, OpenRouter, Mistral, LM Studio…).
LLM_PROVIDER=ollama

# Master switch — set to 0 to disable the LLM entirely and use the keyword
# classifier. The pipeline still runs without an LLM, just with less detail.
OLLAMA_ENABLED=1

# --- Provider: ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=45

# --- Provider: openai-compatible (cloud) ---
# Recommended free tier: Groq (https://console.groq.com — fast, generous quota)
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.1-8b-instant
# OpenAI proper:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
# LM Studio (local, no key needed):
#   OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60
