# Copy to .env and fill in values. NEVER commit .env (it's gitignored).
#
# Only TWO secrets live here:
#   1. MAMBOLEO_WP_URL    — where the scraper pushes data
#   2. MAMBOLEO_API_KEY   — plugin ingestion key (matches MAMBOLEO_API_KEY
#                           constant in mamboleoBack.php)
#
# The LLM provider, model and API key (OpenAI / Groq / etc.) are configured
# in WordPress admin → Mamboleo → AI Intelligence and fetched at startup via
# /wp-json/mamboleo/v1/llm-config. They do NOT belong in this file.

MAMBOLEO_WP_URL=http://localhost/wordpress
MAMBOLEO_API_KEY=mamboleo-dev-key-change-in-production

# Optional: Twitter/X v2 Bearer Token (only needed if X handles are enabled
# in social_sources.yaml). Free Basic tier is enough for our budget.
TWITTER_BEARER_TOKEN=

# Optional: self-hosted RSSHub bridge for Facebook page scraping. When set,
# social_sources.yaml entries with platform: facebook are pulled via
# {RSSHUB_HOST}/facebook/page/{handle}. Leave empty to skip FB sources.
RSSHUB_HOST=

# Scraping behaviour (safe defaults, rarely changed)
SCRAPER_DELAY=2.5
MAX_ARTICLES_PER_RUN=30
