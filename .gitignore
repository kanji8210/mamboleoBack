# scraper/.env is intentionally tracked so prod can `git pull` runtime config.
# REMINDER: rotate MAMBOLEO_API_KEY and OPENAI_API_KEY before making this
# repo public, before adding contributors, or after any laptop is lost.
!scraper/.env

# Python build artefacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Scraper local state
scraper/data/seen.db
scraper/data/*.json
scraper/*.log

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
